---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { linkWhatsApp } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.rascunho);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dataFmt = post.data.data.toLocaleDateString('pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric',
});
---

<Base titulo={post.data.titulo} descricao={post.data.resumo}>
  <article>
    <header class="artigo-topo">
      <div class="container center">
        <a href="/blog" class="artigo-voltar">← Voltar ao blog</a>
        <span class="tag" style="margin-bottom: 1rem;">{post.data.categoria}</span>
        <h1>{post.data.titulo}</h1>
        <p class="artigo-meta">
          Por {post.data.autor} · <time datetime={post.data.data.toISOString()}>{dataFmt}</time>
        </p>
      </div>
    </header>

    {post.data.capa && (
      <div class="container">
        <img src={post.data.capa} alt={post.data.titulo} class="artigo-capa" />
      </div>
    )}

    <div class="container">
      <div class="prose">
        <Content />
      </div>

      <aside class="artigo-cta">
        <h3>Gostou? Isso é só o começo.</h3>
        <p>Na cadeira, a gente cuida do seu cabelo de pertinho. Bora agendar?</p>
        <a href={linkWhatsApp('Oi Lu! Li um post no site e quero agendar 💛')} class="btn btn-primario" target="_blank" rel="noopener">
          Agendar no WhatsApp
        </a>
      </aside>
    </div>
  </article>
</Base>

<style>
  .artigo-topo {
    background: radial-gradient(800px 360px at 50% -30%, var(--areia), transparent), var(--creme);
    padding-block: clamp(2.5rem, 6vw, 4rem) 2rem;
  }
  .artigo-voltar { display: inline-block; font-weight: 600; font-size: 0.92rem; margin-bottom: 1.4rem; }
  .artigo-topo h1 { max-width: 20ch; margin-inline: auto; }
  .artigo-meta { color: var(--tinta-suave); font-size: 0.95rem; margin-top: 0.6rem; }
  .artigo-capa {
    width: 100%;
    max-width: var(--largura-texto);
    margin: 2rem auto 0;
    border-radius: var(--raio);
    box-shadow: var(--sombra);
    aspect-ratio: 16/9;
    object-fit: cover;
  }
  .prose { padding-block: 2.5rem; }
  .artigo-cta {
    max-width: var(--largura-texto);
    margin: 1rem auto 4rem;
    background: var(--creme-2);
    border: 1px solid var(--borda);
    border-radius: var(--raio);
    padding: 2rem;
    text-align: center;
  }
  .artigo-cta p { color: var(--tinta-suave); margin-bottom: 1.2rem; }
</style>
